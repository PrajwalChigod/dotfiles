theme = Catppuccin Mocha
font-family = "IoskeleyMono Nerd Font"
font-style = Regular
font-size = 15
background = "030301"
copy-on-select = true
# keybind = shift+enter=text:\n

# macos specific settings
macos-option-as-alt = true

# Better text rendering
font-thicken = true
adjust-cell-width = 0
adjust-cell-height = 0

# Cursor settings
cursor-style = block
cursor-style-blink = true
cursor-opacity = 1

# Cursor Shaders - Neovide-style animations
# From: https://github.com/KroneCorylus/ghostty-shader-playground
# Restart Ghostty after changing.

custom-shader = shaders/cursor_smear.glsl
# custom-shader = shaders/cursor_smear_fade.glsl

# To disable shaders: comment out all custom-shader lines

# Window visibility
keybind = global:cmd+shift+t=toggle_quick_terminal
